generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GUEST
  USER
  PREMIUM
  ADMIN
  ASSISTANT
}

enum SubscriptionPlan {
  FREE
  PREMIUM
}

enum ResearchStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MessageType {
  RESEARCH_INQUIRY
  COLLABORATION_REQUEST
  GENERAL_MESSAGE
  ADMIN_REPLY
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  image         String?
  role          UserRole  @default(USER)
  subscription  SubscriptionPlan @default(FREE)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  authoredBlogPosts BlogPost[]
  preferences   UserPreference?
  savedItems    SavedItem[]
  researchSubscriptions ResearchSubscription[]
  sentMessages      Message[]       @relation("SentMessages")
  receivedMessages  Message[]       @relation("ReceivedMessages")
  notifications     Notification[]
  researchProjects    ResearchProject[]
  publications      Publication[]
  awards            Award[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BlogPost {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String?  @db.Text
  content        String   @db.Text
  featuredImage  String?
  category       String
  published      Boolean  @default(false)
  publishedAt    DateTime?
  authorId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  author         User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  quote     String   @db.Text
  image     String?
  featured  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Media {
  id         String   @id @default(cuid())
  title      String
  altText    String?
  url        String
  kind       String
  sizeBytes  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteContent {
  id         String   @id @default(cuid())
  key        String   @unique
  title      String
  body       String   @db.Text
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model UserPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  newsletterSubscribed Boolean  @default(false)
  productUpdates       Boolean  @default(false)
  analyticsConsent     Boolean  @default(false)
  marketingConsent     Boolean  @default(false)
  cookieConsentLevel   String   @default("essential")
  theme                String   @default("light")
  locale               String   @default("en")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  type      String
  key       String
  title     String
  href      String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, key])
}

model ProfessionalAffiliation {
  id                String   @id @default(cuid())
  name              String
  role              String
  shortDescription  String   @db.Text
  detailedDescription String  @db.Text
  url               String
  icon              String
  color             String
  displayOrder      Int      @default(0)
  published         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ResearchInterest {
  id                String   @id @default(cuid())
  title             String
  description       String?  @db.Text
  icon              String
  color             String
  displayOrder      Int      @default(0)
  published         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}


model ExternalProfile {
  id                String   @id @default(cuid())
  label             String
  description       String   @db.Text
  url               String
  platform          String
  icon              String
  color             String
  metrics           String?  // JSON string for follower count, etc.
  displayOrder      Int      @default(0)
  published         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Research Hub v2 Models

model ResearchSubscription {
  id          String   @id @default(cuid())
  userId      String
  category    String?  // Specific research category to follow
  keywords    String?  // JSON array of keywords
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model Message {
  id          String      @id @default(cuid())
  senderId    String
  receiverId  String
  subject     String
  content     String      @db.Text
  type        MessageType @default(GENERAL_MESSAGE)
  researchId  String?     // Link to specific research content
  read        Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sender      User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   // RESEARCH_UPDATE, MESSAGE_REPLY, SUBSCRIPTION_ALERT
  read      Boolean  @default(false)
  data      String?  // JSON metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResearchProject {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  summary     String         @db.Text
  content     String?        @db.Text
  category    String
  status      ResearchStatus @default(DRAFT)
  image       String?
  published   Boolean        @default(false)
  publishedAt DateTime?
  tags        String[]       @default([])
  funding     String?
  teamMembers String?        // JSON array of team members
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  authorId    String?
  author      User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model Publication {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  authors     String?
  year        Int
  abstract    String?        @db.Text
  content     String?        @db.Text
  fileUrl     String?
  coverImage  String?
  category    String
  status      ResearchStatus @default(DRAFT)
  published   Boolean        @default(false)
  publishedAt DateTime?
  tags        String[]       @default([])
  doi         String?
  journal     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  authorId    String?
  author      User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model Award {
  id          String         @id @default(cuid())
  title       String
  year        Int
  description String?        @db.Text
  organization String?
  url         String?
  imageUrl    String?
  status      ResearchStatus @default(DRAFT)
  published   Boolean        @default(false)
  publishedAt DateTime?
  tags        String[]       @default([])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  authorId    String?
  author      User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model TeamMember {
  id           String   @id @default(cuid())
  name         String
  role         String
  affiliation  String
  bio          String?  @db.Text
  image        String?
  email        String?
  order        Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ResearchCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  icon        String?
  color       String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
