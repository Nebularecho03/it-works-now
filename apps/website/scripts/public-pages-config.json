{
  "public_pages": [
    {
      "path": "/",
      "name": "Home",
      "description": "Main landing page",
      "requires_auth": false,
      "cache_duration": "1h"
    },
    {
      "path": "/about",
      "name": "About",
      "description": "About Dr. Stephen Asatsa",
      "requires_auth": false,
      "cache_duration": "24h"
    },
    {
      "path": "/admin-signup",
      "name": "Admin Login",
      "description": "Admin portal login page",
      "requires_auth": false,
      "cache_duration": "0h"
    },
    {
      "path": "/admin",
      "name": "Admin Dashboard",
      "description": "Admin control panel",
      "requires_auth": true,
      "cache_duration": "0h"
    },
    {
      "path": "/admin/services",
      "name": "Admin Services",
      "description": "Admin services management",
      "requires_auth": true,
      "cache_duration": "0h"
    },
    {
      "path": "/admin/research",
      "name": "Research Hub",
      "description": "Research projects management",
      "requires_auth": true,
      "cache_duration": "0h"
    },
    {
      "path": "/admin/content",
      "name": "Content Management",
      "description": "Website content management",
      "requires_auth": true,
      "cache_duration": "0h"
    },
    {
      "path": "/admin/media",
      "name": "Media Library",
      "description": "Media and file management",
      "requires_auth": true,
      "cache_duration": "0h"
    },
    {
      "path": "/admin/analytics",
      "name": "Analytics",
      "description": "Website analytics and metrics",
      "requires_auth": true,
      "cache_duration": "0h"
    }
  ],
  "static_routes": [
    {
      "path": "/uploads/*",
      "name": "Uploads",
      "description": "User uploaded files and media",
      "requires_auth": false,
      "cache_duration": "30d"
    },
    {
      "path": "/api/*",
      "name": "API Routes",
      "description": "Backend API endpoints",
      "requires_auth": true,
      "cache_duration": "0h"
    }
  ],
  "security_headers": {
    "x_frame_options": "SAMEORIGIN",
    "x_content_type_options": "nosniff",
    "x_xss_protection": "1; mode=block",
    "referrer_policy": "strict-origin-when-cross-origin",
    "content_security_policy": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:;"
  },
  "nginx_config": {
    "frontend_port": 3002,
    "backend_port": 5001,
    "public_port": 80,
    "ssl_port": 443,
    "worker_processes": "auto",
    "worker_connections": 1024,
    "keepalive_timeout": 65,
    "client_max_body_size": "10M",
    "proxy_timeout": 60,
    "gzip_comp_level": 6
  }
}
